# Get this from the Neon integration in your Vercel dashboard (Storage tab)
# It is set automatically on Vercel; only needed locally.
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"

# Password that unlocks editing (checking problems off + /api/init re-seed).
# Viewing the dashboard never needs it. Set the same value on Vercel
# (Settings -> Environment Variables). If unset, editing stays locked.
EDIT_PASSWORD="choose-a-strong-password"
